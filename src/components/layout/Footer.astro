---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const homeUrl = locale === 'es' ? '/es/' : '/en/';

const navLinks = [
	{ label: t.nav.services, href: '#services' },
	{ label: t.nav.caseStudies, href: '#case-studies' },
	{ label: t.nav.contact, href: '#calendly-section' },
];

const socialLinks = [
	{ label: 'LinkedIn', href: 'https://linkedin.com' },
	{ label: 'Twitter', href: 'https://twitter.com' },
	{ label: 'Instagram', href: 'https://instagram.com' },
];
---

<footer class="border-t border-secondary/10 bg-primary text-white">
	<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">
			<div>
				<a
					href={homeUrl}
					class="cursor-pointer font-heading text-xl font-bold tracking-tight text-white transition-opacity duration-200 hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary"
				>
					We Offsite
				</a>
				<p class="mt-3 max-w-xs text-sm leading-relaxed text-white/80">{t.footer.tagline}</p>
			</div>

			<nav aria-label="Footer navigation">
				<h2 class="font-heading text-sm font-semibold uppercase tracking-wider text-white/60">Links</h2>
				<ul class="mt-4 space-y-3">
					{
						navLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="cursor-pointer text-sm text-white/90 transition-colors duration-200 hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div>
				<h2 class="font-heading text-sm font-semibold uppercase tracking-wider text-white/60">Social</h2>
				<div class="mt-4 flex gap-3">
					{
						socialLinks.map((social) => (
							<a
								href={social.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={social.label}
								class="cursor-pointer rounded-lg bg-white/10 p-2.5 text-white transition-all duration-200 hover:bg-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary"
							>
								{social.label === 'LinkedIn' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
										<rect width="4" height="12" x="2" y="9"></rect>
										<circle cx="4" cy="4" r="2"></circle>
									</svg>
								)}
								{social.label === 'Twitter' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5 5.5 10.5 9 8.5c2.2-1.6 5.6-1.1 7 1.1-2.2-.1-4.4.6-6 2 1.6-1.3 3.5-2.3 5.5-2.3-.9-2.1-3.5-3.4-5.6-2.6 2.1-1.3 4.8-1.6 7.2-.9 1.2-2.5 3.9-4.1 6.8-3.9-2.5 1.9-3.9 5-3.8 8.3 2.6 4.5 7.2 7.3 12 7.2-1.1 2.4-2.8 4.5-4.9 6.1 3.5-.4 6.9-1.8 9.5-4.1-1.1 3.3-4.1 5.9-7.6 6.4 3.3-2 5.5-5.3 5.5-9.1z"></path>
									</svg>
								)}
								{social.label === 'Instagram' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
										<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
										<line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
									</svg>
								)}
							</a>
						))
					}
				</div>
			</div>
		</div>

		<div class="mt-12 border-t border-white/10 pt-8">
			<p class="text-center text-sm text-white/70">{t.footer.legal}</p>
		</div>
	</div>
</footer>
