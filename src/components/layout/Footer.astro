---
import { getTranslations, type Locale } from '../../i18n';
import { getContactUrl } from '../../utils/contact';
import { localeHome, localePath } from '../../utils/paths';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const homeUrl = localeHome(locale);
const aboutUrl = localePath(locale, 'about');
const benefitsUrl = localePath(locale, 'benefits');
const contactUrl = getContactUrl(locale);

const navLinks = [
	{ label: t.nav.about, href: aboutUrl },
	{ label: t.nav.benefits, href: benefitsUrl },
	{ label: t.nav.services, href: `${homeUrl}#services` },
	{ label: t.nav.caseStudies, href: localePath(locale, 'case-studies') },
	{ label: t.nav.contact, href: contactUrl },
];

const socialLinks = [
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/company/we-offsite/' },
	{ label: 'Instagram', href: 'https://www.instagram.com/weoffsite/' },
];
---

<footer class="border-t border-black/[0.06] bg-canvas">
	<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
		<div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
			<div class="lg:col-span-1">
				<a
					href={homeUrl}
					class="cursor-pointer font-heading text-2xl font-bold tracking-tight text-espresso transition-colors duration-200 hover:text-rust"
				>
					We Offsite
				</a>
				<p class="mt-4 max-w-xs text-sm leading-relaxed text-muted">{t.footer.tagline}</p>
			</div>

			<nav aria-label={t.common.footerNav}>
				<p class="chapter-label">{t.common.links}</p>
				<ul class="mt-4 space-y-3">
					{
						navLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="cursor-pointer text-sm text-espresso/80 transition-colors duration-200 hover:text-rust"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div>
				<p class="chapter-label">{t.common.social}</p>
				<div class="mt-4 flex gap-3">
					{
						socialLinks.map((social) => (
							<a
								href={social.href}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={social.label}
								class="cursor-pointer rounded-full border border-black/[0.06] p-2.5 text-espresso transition-all duration-200 hover:border-rust/30 hover:text-rust"
							>
								{social.label === 'LinkedIn' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
										<rect width="4" height="12" x="2" y="9"></rect>
										<circle cx="4" cy="4" r="2"></circle>
									</svg>
								)}
								{social.label === 'Instagram' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
										<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
										<line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
									</svg>
								)}
							</a>
						))
					}
				</div>
			</div>

			<div>
				<p class="chapter-label">Newsletter</p>
				<p class="mt-4 text-sm leading-relaxed text-muted">
					{locale === 'es'
						? 'Inspiración para tu próximo offsite, directo a tu bandeja.'
						: 'Inspiration for your next offsite, straight to your inbox.'}
				</p>
			</div>
		</div>

		<div class="chapter-divider mt-12"></div>
		<p class="text-center font-mono text-xs uppercase tracking-wider text-muted">{t.footer.legal}</p>
	</div>
</footer>
