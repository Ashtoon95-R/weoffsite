---
import type { Locale } from '../../i18n';
import { getTranslations } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const navLinks = [
	{ label: t.nav.services,    href: `/${locale}/#services` },
	{ label: t.nav.caseStudies, href: `/${locale}/#case-studies` },
	{ label: t.nav.contact,     href: `/${locale}/#calendly-section` },
];
---

<footer class="bg-ink py-16">
	<!-- Top separator -->
	<div class="mx-auto max-w-7xl px-6 lg:px-8">
		<div class="mb-12 h-px bg-gold/20"></div>

		<!-- 4-column grid -->
		<div class="grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-4 lg:gap-8">

			<!-- Col 1: Logo + tagline -->
			<div>
				<a
					href={`/${locale}/`}
					class="font-display text-xl font-bold text-parchment transition-opacity duration-200 hover:opacity-75 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
				>
					We Offsite
				</a>
				<p class="mt-3 font-mono text-[11px] uppercase tracking-widest text-mist/70">
					{t.footer.tagline}
				</p>
			</div>

			<!-- Col 2: Navigation links -->
			<div>
				<p class="mb-4 font-mono text-[10px] uppercase tracking-widest text-gold/60">
					Navigation
				</p>
				<nav class="flex flex-col gap-3" aria-label="Footer navigation">
					{
						navLinks.map((link) => (
							<a
								href={link.href}
								class="w-fit cursor-pointer font-body text-sm text-parchment/60 transition-colors duration-200 hover:text-parchment focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
							>
								{link.label}
							</a>
						))
					}
				</nav>
			</div>

			<!-- Col 3: Contact emails -->
			<div>
				<p class="mb-4 font-mono text-[10px] uppercase tracking-widest text-gold/60">
					Contact
				</p>
				<div class="flex flex-col gap-3">
					<a
						href={`mailto:${t.footer.email1}`}
						class="w-fit cursor-pointer font-body text-sm text-parchment/60 transition-colors duration-200 hover:text-parchment focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
					>
						{t.footer.email1}
					</a>
					<a
						href={`mailto:${t.footer.email2}`}
						class="w-fit cursor-pointer font-body text-sm text-parchment/60 transition-colors duration-200 hover:text-parchment focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
					>
						{t.footer.email2}
					</a>
				</div>
			</div>

			<!-- Col 4: Social links -->
			<div>
				<p class="mb-4 font-mono text-[10px] uppercase tracking-widest text-gold/60">
					Social
				</p>
				<div class="flex gap-4">
					<!-- LinkedIn -->
					<a
						href="https://linkedin.com"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
						class="cursor-pointer text-parchment/50 transition-colors duration-200 hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
							<rect width="4" height="12" x="2" y="9" />
							<circle cx="4" cy="4" r="2" />
						</svg>
					</a>

					<!-- Instagram -->
					<a
						href="https://instagram.com"
						target="_blank"
						rel="noopener noreferrer"
						aria-label="Instagram"
						class="cursor-pointer text-parchment/50 transition-colors duration-200 hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
							<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
							<line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
						</svg>
					</a>
				</div>
			</div>
		</div>

		<!-- Bottom legal row -->
		<div class="mt-12 h-px bg-gold/10"></div>
		<div class="mt-6 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
			<p class="font-mono text-[10px] uppercase tracking-widest text-mist/50">
				{t.footer.legal}
			</p>
			<p class="font-mono text-[10px] uppercase tracking-widest text-mist/30">
				We Offsite · Since 2022
			</p>
		</div>
	</div>
</footer>
