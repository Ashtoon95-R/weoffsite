---
import Button from '../ui/Button.astro';
import { getLocaleSwitchUrl, getTranslations, type Locale } from '../../i18n';
import { getContactUrl } from '../../utils/contact';
import { localeHome, localePath } from '../../utils/paths';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const enUrl = getLocaleSwitchUrl('en', Astro.url.pathname, Astro.url.hash);
const esUrl = getLocaleSwitchUrl('es', Astro.url.pathname, Astro.url.hash);
const homeUrl = localeHome(locale);
const aboutUrl = localePath(locale, 'about');
const benefitsUrl = localePath(locale, 'benefits');
const pathname = Astro.url.pathname;
const loginUrl = 'https://app.weoffsite.com/login';
const contactUrl = getContactUrl(locale);
const calendlyUrl = `${homeUrl}#calendly-section`;

const navLinks = [
	{ label: t.nav.about, href: aboutUrl },
	{ label: t.nav.benefits, href: benefitsUrl },
	{ label: t.nav.services, href: `${homeUrl}#services` },
	{ label: t.nav.caseStudies, href: localePath(locale, 'case-studies') },
	{ label: t.nav.contact, href: contactUrl },
];

const headerBtnClass = '!px-4 !py-2 !text-sm shrink-0 whitespace-nowrap';

function isActive(href: string) {
	if (href.startsWith('#')) return false;
	if (href.includes('#')) return pathname === homeUrl || pathname === `${homeUrl}`;
	if (href === contactUrl) return pathname === contactUrl;
	const normalized = href.endsWith('/') ? href : `${href}/`;
	return pathname === normalized || pathname.startsWith(normalized);
}
---

<div class="pointer-events-none fixed inset-x-0 top-0 z-50 px-4 pt-4 lg:px-6">
	<header
		id="site-header"
		class="pointer-events-auto mx-auto max-w-7xl rounded-2xl border border-black/[0.06] bg-white/85 shadow-sm backdrop-blur-xl transition-all duration-300 ease-editorial lg:rounded-full"
		data-open-menu={t.common.openMenu}
		data-close-menu={t.common.closeMenu}
	>
		<div class="flex items-center gap-3 px-4 py-3 sm:px-6 lg:gap-4 lg:py-3.5">
			<a
				href={homeUrl}
				class="shrink-0 cursor-pointer transition-opacity duration-200 hover:opacity-85"
				aria-label={t.common.brandName}
			>
				<img
					src="/icon/Logo-Completo.webp"
					alt={t.common.brandName}
					width="1335"
					height="486"
					class="h-7 w-auto lg:h-8"
					loading="eager"
					decoding="async"
				/>
			</a>

			<nav class="hidden flex-1 items-center justify-center gap-0.5 xl:gap-1 lg:flex" aria-label={t.common.mainNav}>
				{
					navLinks.map((link) => (
						<a
							href={link.href}
							class:list={[
								'cursor-pointer whitespace-nowrap rounded-full px-2.5 py-1.5 text-[13px] font-medium transition-all duration-200 ease-editorial xl:px-3 xl:text-sm',
								isActive(link.href)
									? 'bg-espresso/[0.06] text-espresso underline decoration-gold decoration-2 underline-offset-4'
									: 'text-muted hover:bg-espresso/[0.04] hover:text-espresso',
							]}
						>
							{link.label}
						</a>
					))
				}
			</nav>

			<div class="hidden shrink-0 items-center gap-2 lg:flex xl:gap-3">
				<div class="flex items-center gap-0.5 rounded-full border border-black/[0.06] p-0.5" role="group" aria-label={t.common.languageSelector}>
					<a
						href={esUrl}
						class:list={[
							'cursor-pointer rounded-full px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-wider transition-all duration-200',
							locale === 'es' ? 'bg-espresso text-white' : 'text-muted hover:text-espresso',
						]}
						hreflang="es"
					>
						ES
					</a>
					<a
						href={enUrl}
						class:list={[
							'cursor-pointer rounded-full px-2.5 py-1 font-mono text-[10px] font-bold uppercase tracking-wider transition-all duration-200',
							locale === 'en' ? 'bg-espresso text-white' : 'text-muted hover:text-espresso',
						]}
						hreflang="en"
					>
						EN
					</a>
				</div>
				<Button href={loginUrl} variant="secondary" showArrow={false} class={headerBtnClass}>{t.nav.login}</Button>
				<Button href={calendlyUrl} showArrow={false} class={headerBtnClass}>{t.nav.cta}</Button>
			</div>

			<button
				type="button"
				id="menu-toggle"
				class="ml-auto flex h-10 w-10 shrink-0 cursor-pointer flex-col items-center justify-center gap-1.5 rounded-full transition-colors duration-200 hover:bg-espresso/[0.04] lg:hidden"
				aria-expanded="false"
				aria-controls="mobile-menu"
				aria-label={t.common.openMenu}
			>
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
			</button>
		</div>

		<div id="mobile-menu" class="hidden border-t border-black/[0.06] lg:hidden" aria-hidden="true">
			<nav class="flex flex-col gap-1 px-4 py-4" aria-label={t.common.mobileNav}>
				{
					navLinks.map((link, i) => (
						<a
							href={link.href}
							class="mobile-nav-link cursor-pointer rounded-xl px-4 py-3 text-base font-medium text-espresso transition-all duration-200 hover:bg-espresso/[0.04]"
							style={`animation-delay: ${(i + 1) * 50}ms`}
						>
							{link.label}
						</a>
					))
				}
				<div class="mt-4 flex flex-col gap-3 border-t border-black/[0.06] pt-4">
					<Button href={loginUrl} variant="secondary" showArrow={false} class="w-full">{t.nav.login}</Button>
					<Button href={calendlyUrl} showArrow={false} class="w-full">{t.nav.cta}</Button>
				</div>
				<div class="mt-4 flex items-center gap-2 border-t border-black/[0.06] pt-4">
					<a
						href={esUrl}
						class:list={[
							'cursor-pointer flex-1 rounded-full px-3 py-2 text-center font-mono text-xs font-bold uppercase tracking-wider',
							locale === 'es' ? 'bg-espresso text-white' : 'border border-black/[0.06] text-muted',
						]}
						hreflang="es"
					>
						ES
					</a>
					<a
						href={enUrl}
						class:list={[
							'cursor-pointer flex-1 rounded-full px-3 py-2 text-center font-mono text-xs font-bold uppercase tracking-wider',
							locale === 'en' ? 'bg-espresso text-white' : 'border border-black/[0.06] text-muted',
						]}
						hreflang="en"
					>
						EN
					</a>
				</div>
			</nav>
		</div>
	</header>
</div>

<script>
	const header = document.getElementById('site-header');
	const toggle = document.getElementById('menu-toggle');
	const menu = document.getElementById('mobile-menu');

	const openMenuLabel = header?.dataset.openMenu ?? 'Open menu';
	const closeMenuLabel = header?.dataset.closeMenu ?? 'Close menu';

	function closeMenu() {
		menu?.classList.add('hidden');
		menu?.setAttribute('aria-hidden', 'true');
		toggle?.setAttribute('aria-expanded', 'false');
		toggle?.setAttribute('aria-label', openMenuLabel);
		toggle?.classList.remove('menu-open');
	}

	function openMenu() {
		menu?.classList.remove('hidden');
		menu?.setAttribute('aria-hidden', 'false');
		toggle?.setAttribute('aria-expanded', 'true');
		toggle?.setAttribute('aria-label', closeMenuLabel);
		toggle?.classList.add('menu-open');
	}

	toggle?.addEventListener('click', () => {
		const isOpen = toggle.getAttribute('aria-expanded') === 'true';
		if (isOpen) closeMenu();
		else openMenu();
	});

	document.querySelectorAll('.mobile-nav-link').forEach((link) => {
		link.addEventListener('click', closeMenu);
	});

	window.addEventListener('scroll', () => {
		if (!header) return;
		header.classList.toggle('shadow-md', window.scrollY > 24);
	});
</script>
