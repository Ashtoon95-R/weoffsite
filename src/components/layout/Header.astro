---
import Button from '../ui/Button.astro';
import { getLocaleSwitchUrl, getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const enUrl = getLocaleSwitchUrl('en', Astro.url.pathname, Astro.url.hash);
const esUrl = getLocaleSwitchUrl('es', Astro.url.pathname, Astro.url.hash);
const homeUrl = locale === 'es' ? '/es/' : '/en/';
const aboutUrl = `${homeUrl}about`;
const benefitsUrl = `${homeUrl}benefits`;

const navLinks = [
	{ label: t.nav.about, href: aboutUrl },
	{ label: t.nav.benefits, href: benefitsUrl },
	{ label: t.nav.services, href: `${homeUrl}#services` },
	{ label: t.nav.caseStudies, href: `${homeUrl}case-studies` },
	{ label: t.nav.contact, href: '#calendly-section' },
];
---

<header
	id="site-header"
	class="sticky top-0 z-50 border-b border-transparent bg-background/95 backdrop-blur-sm transition-all duration-200"
	data-open-menu={t.common.openMenu}
	data-close-menu={t.common.closeMenu}
>
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
		<a
			href={homeUrl}
			class="cursor-pointer font-heading text-xl font-bold tracking-tight text-primary transition-colors duration-200 hover:text-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
			aria-label={t.common.brandName}
		>
			<svg
				width="140"
				height="28"
				viewBox="0 0 140 28"
				fill="none"
				xmlns="http://www.w3.org/2000/svg"
				aria-hidden="true"
				class="h-7 w-auto"
			>
				<text x="0" y="22" fill="currentColor" font-family="Lexend, sans-serif" font-size="20" font-weight="700">
					We Offsite
				</text>
			</svg>
		</a>

		<nav class="hidden items-center gap-8 md:flex" aria-label={t.common.mainNav}>
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class="cursor-pointer text-sm font-medium text-secondary transition-colors duration-200 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<div class="hidden items-center gap-4 md:flex">
			<div class="flex items-center gap-1 rounded-lg border border-secondary/20 p-1" role="group" aria-label={t.common.languageSelector}>
				<a
					href={esUrl}
					class:list={[
						'cursor-pointer rounded-md px-2.5 py-1 text-xs font-semibold uppercase transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
						locale === 'es' ? 'bg-primary text-white' : 'text-secondary hover:text-primary',
					]}
					hreflang="es"
				>
					ES
				</a>
				<a
					href={enUrl}
					class:list={[
						'cursor-pointer rounded-md px-2.5 py-1 text-xs font-semibold uppercase transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
						locale === 'en' ? 'bg-primary text-white' : 'text-secondary hover:text-primary',
					]}
					hreflang="en"
				>
					EN
				</a>
			</div>
			<Button href="#calendly-section">{t.nav.cta}</Button>
		</div>

		<button
			type="button"
			id="menu-toggle"
			class="cursor-pointer rounded-lg p-2 text-primary transition-colors duration-200 hover:bg-primary/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 md:hidden"
			aria-expanded="false"
			aria-controls="mobile-menu"
			aria-label={t.common.openMenu}
		>
			<svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<line x1="4" x2="20" y1="12" y2="12"></line>
				<line x1="4" x2="20" y1="6" y2="6"></line>
				<line x1="4" x2="20" y1="18" y2="18"></line>
			</svg>
			<svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<path d="M18 6 6 18"></path>
				<path d="m6 6 12 12"></path>
			</svg>
		</button>
	</div>

	<div id="mobile-menu" class="hidden border-t border-secondary/10 bg-background md:hidden" aria-hidden="true">
		<nav class="mx-auto flex max-w-7xl flex-col gap-1 px-4 py-4 sm:px-6" aria-label={t.common.mobileNav}>
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class="mobile-nav-link cursor-pointer rounded-lg px-3 py-3 text-base font-medium text-secondary transition-colors duration-200 hover:bg-primary/5 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
					>
						{link.label}
					</a>
				))
			}
			<div class="mt-3 flex items-center gap-2 border-t border-secondary/10 pt-4">
				<a
					href={esUrl}
					class:list={[
						'cursor-pointer flex-1 rounded-lg px-3 py-2 text-center text-sm font-semibold uppercase transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent',
						locale === 'es' ? 'bg-primary text-white' : 'border border-secondary/20 text-secondary hover:text-primary',
					]}
					hreflang="es"
				>
					ES
				</a>
				<a
					href={enUrl}
					class:list={[
						'cursor-pointer flex-1 rounded-lg px-3 py-2 text-center text-sm font-semibold uppercase transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent',
						locale === 'en' ? 'bg-primary text-white' : 'border border-secondary/20 text-secondary hover:text-primary',
					]}
					hreflang="en"
				>
					EN
				</a>
			</div>
			<Button href="#calendly-section" class="mt-4 w-full">{t.nav.cta}</Button>
		</nav>
	</div>
</header>

<script>
	const header = document.getElementById('site-header');
	const toggle = document.getElementById('menu-toggle');
	const menu = document.getElementById('mobile-menu');
	const iconMenu = document.getElementById('icon-menu');
	const iconClose = document.getElementById('icon-close');

	const openMenuLabel = header?.dataset.openMenu ?? 'Open menu';
	const closeMenuLabel = header?.dataset.closeMenu ?? 'Close menu';

	function closeMenu() {
		menu?.classList.add('hidden');
		menu?.setAttribute('aria-hidden', 'true');
		toggle?.setAttribute('aria-expanded', 'false');
		toggle?.setAttribute('aria-label', openMenuLabel);
		iconMenu?.classList.remove('hidden');
		iconClose?.classList.add('hidden');
	}

	function openMenu() {
		menu?.classList.remove('hidden');
		menu?.setAttribute('aria-hidden', 'false');
		toggle?.setAttribute('aria-expanded', 'true');
		toggle?.setAttribute('aria-label', closeMenuLabel);
		iconMenu?.classList.add('hidden');
		iconClose?.classList.remove('hidden');
	}

	toggle?.addEventListener('click', () => {
		const isOpen = toggle.getAttribute('aria-expanded') === 'true';
		if (isOpen) closeMenu();
		else openMenu();
	});

	document.querySelectorAll('.mobile-nav-link').forEach((link) => {
		link.addEventListener('click', closeMenu);
	});

	window.addEventListener('scroll', () => {
		if (!header) return;
		header.classList.toggle('border-secondary/10', window.scrollY > 8);
		header.classList.toggle('shadow-sm', window.scrollY > 8);
	});
</script>
