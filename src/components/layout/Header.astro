---
import type { Locale } from '../../i18n';
import { getTranslations } from '../../i18n';
import Button from '../ui/Button.astro';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const navLinks = [
	{ label: t.nav.services,    href: `/${locale}/#services` },
	{ label: t.nav.caseStudies, href: `/${locale}/#case-studies` },
	{ label: t.nav.contact,     href: `/${locale}/#calendly-section` },
];

const altLocale = locale === 'es' ? 'en' : 'es';
const altLabel  = locale === 'es' ? 'EN' : 'ES';
const curLabel  = locale === 'es' ? 'ES' : 'EN';
---

<header
	id="site-header"
	class="fixed left-0 right-0 top-0 z-50 transition-all duration-300"
>
	<div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">

		<!-- Logo -->
		<a
			href={`/${locale}/`}
			class="font-display text-xl font-bold text-parchment transition-opacity duration-200 hover:opacity-75 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
			aria-label="We Offsite — Home"
		>
			We Offsite
		</a>

		<!-- Desktop nav -->
		<nav class="hidden items-center gap-8 lg:flex" aria-label="Main navigation">
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class="cursor-pointer font-mono text-[11px] uppercase tracking-widest text-parchment/70 transition-colors duration-200 hover:text-gold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<!-- Right side: locale switcher + CTA -->
		<div class="flex items-center gap-4">
			<!-- Locale switcher -->
			<div class="flex items-center gap-1 font-mono text-[11px] uppercase tracking-widest">
				<span class="cursor-default text-gold">{curLabel}</span>
				<span class="text-parchment/30">/</span>
				<a
					href={`/${altLocale}/`}
					class="cursor-pointer text-parchment/50 transition-colors duration-200 hover:text-parchment focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
				>
					{altLabel}
				</a>
			</div>

			<!-- CTA button (desktop) -->
			<div class="hidden lg:block">
				<Button href={`/${locale}/#calendly-section`} variant="rust">
					{t.nav.cta}
				</Button>
			</div>

			<!-- Mobile hamburger -->
			<button
				id="hamburger"
				type="button"
				class="relative flex h-8 w-8 cursor-pointer flex-col items-center justify-center gap-[5px] lg:hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-gold"
				aria-label="Toggle menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<span class="hamburger-line block h-px w-5 bg-parchment transition-all duration-300" />
				<span class="hamburger-line block h-px w-5 bg-parchment transition-all duration-300" />
				<span class="hamburger-line block h-px w-5 bg-parchment transition-all duration-300" />
			</button>
		</div>
	</div>

	<!-- Mobile menu -->
	<div
		id="mobile-menu"
		class="hidden border-t border-gold/20 px-6 pb-6 pt-4"
		style="background-color: rgba(13,13,11,0.97); backdrop-filter: blur(8px);"
		role="navigation"
		aria-label="Mobile navigation"
	>
		<nav class="flex flex-col gap-5">
			{
				navLinks.map((link) => (
					<a
						href={link.href}
						class="cursor-pointer font-mono text-sm uppercase tracking-widest text-parchment/70 transition-colors duration-200 hover:text-gold"
					>
						{link.label}
					</a>
				))
			}
			<Button href={`/${locale}/#calendly-section`} variant="rust" class="self-start mt-2">
				{t.nav.cta}
			</Button>
		</nav>
	</div>
</header>

<script>
	const header  = document.getElementById('site-header');
	const hamburger  = document.getElementById('hamburger');
	const mobileMenu = document.getElementById('mobile-menu');

	// Scroll: transparent → opaque ink background
	window.addEventListener('scroll', () => {
		if (!header) return;
		if (window.scrollY > 60) {
			header.style.backgroundColor = 'rgba(13, 13, 11, 0.95)';
			header.style.backdropFilter  = 'blur(8px)';
			header.style.borderBottom    = '1px solid rgba(201, 168, 76, 0.15)';
		} else {
			header.style.backgroundColor = 'transparent';
			header.style.backdropFilter  = 'none';
			header.style.borderBottom    = 'none';
		}
	}, { passive: true });

	// Mobile hamburger toggle
	hamburger?.addEventListener('click', () => {
		const isOpen = mobileMenu?.classList.contains('hidden') === false;
		if (isOpen) {
			mobileMenu?.classList.add('hidden');
			hamburger?.setAttribute('aria-expanded', 'false');
		} else {
			mobileMenu?.classList.remove('hidden');
			hamburger?.setAttribute('aria-expanded', 'true');
		}
	});

	// Close mobile menu when a nav link is clicked
	mobileMenu?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			mobileMenu.classList.add('hidden');
			hamburger?.setAttribute('aria-expanded', 'false');
		});
	});
</script>
