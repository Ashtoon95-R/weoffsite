---
interface Props {
	variant?: 'primary' | 'secondary';
	href?: string;
	class?: string;
}

const { variant = 'primary', href, class: className = '' } = Astro.props;

const base =
	'inline-flex items-center justify-center rounded-lg px-6 py-3 text-base font-semibold transition-all duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2';

const variants = {
	primary: 'bg-cta text-white hover:opacity-90 hover:-translate-y-0.5',
	secondary:
		'border-2 border-primary bg-transparent text-primary hover:bg-primary/5 hover:-translate-y-0.5',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{
	href ? (
		<a href={href} class={classes}>
			<slot />
		</a>
	) : (
		<button type="button" class={classes}>
			<slot />
		</button>
	)
}
