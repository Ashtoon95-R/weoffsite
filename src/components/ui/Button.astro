---
interface Props {
	variant?: 'primary' | 'secondary';
	href?: string;
	type?: 'button' | 'submit';
	class?: string;
	showArrow?: boolean;
}

const { variant = 'primary', href, type = 'button', class: className = '', showArrow = true } = Astro.props;

const base =
	'group inline-flex cursor-pointer items-center justify-center gap-2 rounded-full px-6 py-3 text-base font-semibold transition-all duration-300 ease-editorial focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:scale-[0.98]';

const variants = {
	primary: 'bg-rust text-white shadow-editorial hover:bg-rust/90 hover:-translate-y-0.5',
	secondary:
		'border-2 border-espresso/20 bg-transparent text-espresso hover:border-espresso/40 hover:bg-espresso/[0.03]',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{
	href ? (
		<a href={href} class={classes}>
			<slot />
			{showArrow && variant === 'primary' && (
				<span
					class="flex h-8 w-8 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 ease-editorial group-hover:translate-x-0.5 group-hover:-translate-y-px group-active:scale-105"
					aria-hidden="true"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5 12h14"></path>
						<path d="m12 5 7 7-7 7"></path>
					</svg>
				</span>
			)}
		</a>
	) : (
		<button type={type} class={classes}>
			<slot />
			{showArrow && variant === 'primary' && (
				<span
					class="flex h-8 w-8 items-center justify-center rounded-full bg-white/15 transition-transform duration-300 ease-editorial group-hover:translate-x-0.5 group-hover:-translate-y-px group-active:scale-105"
					aria-hidden="true"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M5 12h14"></path>
						<path d="m12 5 7 7-7 7"></path>
					</svg>
				</span>
			)}
		</button>
	)
}
