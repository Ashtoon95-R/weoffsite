---
import type { ImageMetadata } from 'astro';

type Variant = 'hero' | 'featured' | 'card' | 'thumb' | 'detail';

interface Props {
	src: ImageMetadata;
	alt: string;
	variant?: Variant;
	loading?: 'lazy' | 'eager';
	class?: string;
	onload?: string;
}

const { src, alt, variant = 'card', loading = 'lazy', class: className = '', onload } = Astro.props;

/** Sources are pre-optimized WebP — serve directly to avoid lossy re-encoding. */
const sizes: Record<Variant, string | undefined> = {
	hero: '(min-width: 1024px) 480px, 100vw',
	featured: '(min-width: 1024px) 66vw, 100vw',
	card: '(min-width: 1024px) 33vw, 50vw',
	thumb: '(min-width: 640px) 33vw, 50vw',
	detail: '(min-width: 1024px) 960px, 100vw',
};
---

<img
	src={src.src}
	alt={alt}
	width={src.width}
	height={src.height}
	sizes={sizes[variant]}
	loading={loading}
	decoding="async"
	class={className}
	onload={onload}
/>
