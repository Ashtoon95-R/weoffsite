---
import Card from '../ui/Card.astro';
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const serviceCards = [
	{ key: 'meetings', icon: 'building2' },
	{ key: 'retreats', icon: 'users' },
	{ key: 'logistics', icon: 'package' },
] as const;
---

<section id="services" class="bg-canvas py-20 md:py-28" aria-labelledby="services-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal max-w-2xl">
			<p class="chapter-label">{locale === 'es' ? 'Servicios' : 'Services'}</p>
			<h2 id="services-title" class="mt-3 editorial-heading text-3xl md:text-4xl lg:text-5xl">
				{t.services.title}
			</h2>
			<div class="chapter-divider"></div>
		</div>

		<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
			{
				serviceCards.map(({ key, icon }, i) => {
					const item = t.services[key];
					return (
						<Card class:list={['reveal h-full', i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2']}>
							<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-rust/10 text-rust">
								{icon === 'building2' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path d="M10 12h4"></path>
										<path d="M10 8h4"></path>
										<path d="M14 21v-3a2 2 0 0 0-4 0v3"></path>
										<path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-2"></path>
										<path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"></path>
									</svg>
								)}
								{icon === 'users' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
										<circle cx="9" cy="7" r="4"></circle>
										<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
										<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
									</svg>
								)}
								{icon === 'package' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path>
										<polyline points="12 22 12 12"></polyline>
										<polyline points="3.29 7 12 12 20.71 7"></polyline>
										<path d="m7.5 4.27 9 5.15"></path>
									</svg>
								)}
							</div>
							<h3 class="mt-6 font-heading text-xl font-bold text-espresso">{item.title}</h3>
							<p class="mt-3 text-base leading-relaxed text-muted">{item.desc}</p>
						</Card>
					);
				})
			}
		</div>
	</div>
</section>
