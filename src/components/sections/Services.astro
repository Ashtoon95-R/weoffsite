---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const serviceCards = [
	{ key: 'meetings', icon: 'building2' },
	{ key: 'retreats', icon: 'users' },
	{ key: 'logistics', icon: 'package' },
] as const;
---

<section id="services" class="bg-white py-16 md:py-24" aria-labelledby="services-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<h2 id="services-title" class="max-w-3xl font-heading text-3xl font-bold tracking-tight text-primary md:text-4xl">
			{t.services.title}
		</h2>

		<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
			{
				serviceCards.map(({ key, icon }) => {
					const item = t.services[key];
					return (
						<article class="rounded-xl bg-background p-8 shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg">
							<div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent/10 text-accent">
								{icon === 'building2' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M10 12h4"></path>
										<path d="M10 8h4"></path>
										<path d="M14 21v-3a2 2 0 0 0-4 0v3"></path>
										<path d="M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-2"></path>
										<path d="M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16"></path>
									</svg>
								)}
								{icon === 'users' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
										<circle cx="9" cy="7" r="4"></circle>
										<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
										<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
									</svg>
								)}
								{icon === 'package' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"></path>
										<polyline points="12 22 12 12"></polyline>
										<polyline points="3.29 7 12 12 20.71 7"></polyline>
										<path d="m7.5 4.27 9 5.15"></path>
									</svg>
								)}
							</div>
							<h3 class="mt-6 font-heading text-xl font-semibold text-primary">{item.title}</h3>
							<p class="mt-3 text-base leading-relaxed text-secondary">{item.desc}</p>
						</article>
					);
				})
			}
		</div>
	</div>
</section>
