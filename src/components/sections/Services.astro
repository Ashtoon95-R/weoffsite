---
import type { Locale } from '../../i18n';
import { getTranslations } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const cards = [
	{
		icon: 'calendar',
		title: t.services.meetings.title,
		desc: t.services.meetings.desc,
		popular: false,
	},
	{
		icon: 'users',
		title: t.services.retreats.title,
		desc: t.services.retreats.desc,
		popular: true,
	},
	{
		icon: 'package',
		title: t.services.logistics.title,
		desc: t.services.logistics.desc,
		popular: false,
	},
];
---

<section id="services" class="bg-forest py-20 lg:py-28">
	<div class="mx-auto max-w-7xl px-6 lg:px-8">

		<!-- Section header -->
		<div class="reveal">
			<h2 class="font-display text-[40px] font-bold leading-[1.05] text-parchment lg:text-[56px]">
				{t.services.title}
			</h2>
		</div>

		<!-- Cards grid -->
		<div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
			{
				cards.map((card, i) => (
					<article
						class="reveal group relative cursor-default border border-gold/40 p-8 transition-all duration-300 hover:border-gold"
						style="background-color: #3A5C3B;"
						data-delay={i * 100}
					>
						{card.popular && (
							<span class="absolute right-4 top-4 font-mono text-[10px] uppercase tracking-widest text-gold">
								{t.services.popular}
							</span>
						)}

						<!-- Lucide icon (inline SVG) in gold -->
						<div class="mb-6 text-gold" aria-hidden="true">
							{card.icon === 'calendar' && (
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="32"
									height="32"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
									<line x1="16" x2="16" y1="2" y2="6" />
									<line x1="8" x2="8" y1="2" y2="6" />
									<line x1="3" x2="21" y1="10" y2="10" />
								</svg>
							)}
							{card.icon === 'users' && (
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="32"
									height="32"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
									<circle cx="9" cy="7" r="4" />
									<path d="M22 21v-2a4 4 0 0 0-3-3.87" />
									<path d="M16 3.13a4 4 0 0 1 0 7.75" />
								</svg>
							)}
							{card.icon === 'package' && (
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="32"
									height="32"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z" />
									<path d="M12 22V12" />
									<path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7" />
									<path d="m7.5 4.27 9 5.15" />
								</svg>
							)}
						</div>

						<h3 class="font-body text-xl font-semibold text-parchment">
							{card.title}
						</h3>
						<p class="mt-3 font-body text-[15px] leading-relaxed text-mist">
							{card.desc}
						</p>
					</article>
				))
			}
		</div>
	</div>
</section>
