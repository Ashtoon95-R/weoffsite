---
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section
	class="editorial-hero-bg relative overflow-hidden border-b border-black/[0.06] py-20 md:py-28"
	aria-labelledby="case-studies-page-title"
>
	<div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal max-w-3xl">
			<p class="chapter-label">{t.caseStudies.label}</p>
			<h1 id="case-studies-page-title" class="editorial-heading mt-4 text-[clamp(2rem,5vw,3.5rem)] leading-tight">
				{t.caseStudies.pageTitle}
			</h1>
			<p class="mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
				{t.caseStudies.pageSubtitle}
			</p>
		</div>
	</div>
</section>
