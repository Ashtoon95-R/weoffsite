---
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section
	class="relative overflow-hidden bg-gradient-to-br from-primary via-secondary to-accent py-20 md:py-28"
	aria-labelledby="case-studies-page-title"
>
	<div
		class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(3,105,161,0.35),transparent_55%)]"
		aria-hidden="true"
	></div>
	<div class="absolute inset-0 bg-black/20" aria-hidden="true"></div>

	<div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-widest text-white/70">{t.caseStudies.label}</p>
			<h1
				id="case-studies-page-title"
				class="mt-4 font-heading text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl md:text-5xl"
			>
				{t.caseStudies.pageTitle}
			</h1>
			<p class="mt-6 max-w-2xl text-base leading-relaxed text-white/90 sm:text-lg">
				{t.caseStudies.pageSubtitle}
			</p>
		</div>
	</div>
</section>
