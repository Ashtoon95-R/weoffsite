---
import Button from '../../ui/Button.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="bg-primary py-16 md:py-24" aria-labelledby="about-final-cta-title">
	<div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
		<h2 id="about-final-cta-title" class="font-heading text-3xl font-bold tracking-tight text-white md:text-4xl">
			{t.about.finalCta.title}
		</h2>
		<p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg">
			{t.about.finalCta.subtitle}
		</p>
		<div class="mt-10">
			<Button href="#calendly-section">{t.about.finalCta.cta}</Button>
		</div>
	</div>
</section>
