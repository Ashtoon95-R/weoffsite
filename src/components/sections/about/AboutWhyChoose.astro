---
import Card from '../../ui/Card.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const benefits = ['expenses', 'rates', 'support', 'time', 'policy', 'allInOne'] as const;
---

<section class="bg-surface py-20 md:py-28" aria-labelledby="about-why-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal max-w-2xl">
			<p class="chapter-label">{locale === 'es' ? 'Ventajas' : 'Why us'}</p>
			<h2 id="about-why-title" class="mt-3 editorial-heading text-3xl md:text-4xl">
				{t.about.whyChoose.title}
			</h2>
			<div class="chapter-divider"></div>
		</div>

		<div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				benefits.map((key, i) => {
					const item = t.about.whyChoose[key];
					return (
						<Card padding="sm" class:list={['reveal', i % 3 === 1 && 'reveal-delay-1', i % 3 === 2 && 'reveal-delay-2']}>
							<p class="font-mono text-[10px] uppercase tracking-wider text-rust">{String(i + 1).padStart(2, '0')}</p>
							<h3 class="mt-3 font-heading text-lg font-bold text-espresso">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-muted">{item.desc}</p>
						</Card>
					);
				})
			}
		</div>
	</div>
</section>
