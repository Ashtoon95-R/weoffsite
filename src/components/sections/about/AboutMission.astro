---
import Button from '../../ui/Button.astro';
import Card from '../../ui/Card.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const pillars = ['expertise', 'purpose', 'model'] as const;
---

<section class="bg-surface py-20 md:py-28" aria-labelledby="about-mission-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal mx-auto max-w-3xl text-center">
			<p class="chapter-label">{t.about.mission.label}</p>
			<h2 id="about-mission-title" class="mt-4 editorial-heading text-3xl md:text-4xl lg:text-5xl">
				{t.about.mission.title}
			</h2>
			<div class="chapter-divider mx-auto max-w-xs"></div>
		</div>

		<div class="mt-14 grid grid-cols-1 gap-8 lg:grid-cols-3">
			{
				pillars.map((key, i) => {
					const item = t.about.mission[key];
					return (
						<Card class:list={['reveal h-full', i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2']}>
							<p class="font-mono text-xs uppercase tracking-wider text-sage">{String(i + 1).padStart(2, '0')}</p>
							<h3 class="mt-4 font-heading text-xl font-bold text-espresso">{item.title}</h3>
							<p class="mt-3 text-base leading-relaxed text-muted">{item.desc}</p>
						</Card>
					);
				})
			}
		</div>

		<div class="reveal mt-14 text-center">
			<Button href="#calendly-section">{t.about.hero.cta}</Button>
		</div>
	</div>
</section>
