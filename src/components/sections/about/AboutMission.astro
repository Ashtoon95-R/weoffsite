---
import Button from '../../ui/Button.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const pillars = [
	{ key: 'expertise' as const, icon: 'sparkles' },
	{ key: 'purpose' as const, icon: 'target' },
	{ key: 'model' as const, icon: 'handshake' },
];
---

<section class="bg-white py-16 md:py-24" aria-labelledby="about-mission-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl text-center md:mx-auto">
			<p class="text-sm font-semibold uppercase tracking-widest text-accent">{t.about.mission.label}</p>
			<h2
				id="about-mission-title"
				class="mt-4 font-heading text-3xl font-bold tracking-tight text-primary md:text-4xl"
			>
				{t.about.mission.title}
			</h2>
		</div>

		<div class="mt-14 grid grid-cols-1 gap-8 lg:grid-cols-3">
			{
				pillars.map(({ key, icon }) => {
					const item = t.about.mission[key];
					return (
						<article class="rounded-xl bg-background p-8 shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg">
							<div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent/10 text-accent">
								{icon === 'sparkles' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"></path>
										<path d="M20 3v4"></path>
										<path d="M22 5h-4"></path>
										<path d="M4 17v2"></path>
										<path d="M5 18H3"></path>
									</svg>
								)}
								{icon === 'target' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<circle cx="12" cy="12" r="10"></circle>
										<circle cx="12" cy="12" r="6"></circle>
										<circle cx="12" cy="12" r="2"></circle>
									</svg>
								)}
								{icon === 'handshake' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="m11 17 2 2a1 1 0 1 0 3-3"></path>
										<path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"></path>
										<path d="m21 3 1 11h-2"></path>
										<path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"></path>
										<path d="M3 4h8"></path>
									</svg>
								)}
							</div>
							<h3 class="mt-6 font-heading text-xl font-semibold text-primary">{item.title}</h3>
							<p class="mt-3 text-base leading-relaxed text-secondary">{item.desc}</p>
						</article>
					);
				})
			}
		</div>

		<div class="mt-14 text-center">
			<Button href="#calendly-section">{t.about.hero.cta}</Button>
		</div>
	</div>
</section>
