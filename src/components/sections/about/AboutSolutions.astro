---
import Button from '../../ui/Button.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const solutions = [
	{ key: 'offsites' as const, icon: 'map' },
	{ key: 'events' as const, icon: 'calendar' },
	{ key: 'meetups' as const, icon: 'users' },
];
---

<section id="about-solutions" class="bg-background py-16 md:py-24" aria-labelledby="about-solutions-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<h2 id="about-solutions-title" class="font-heading text-3xl font-bold tracking-tight text-primary md:text-4xl">
			{t.about.solutions.title}
		</h2>

		<div class="mt-12 grid grid-cols-1 gap-8 lg:grid-cols-3">
			{
				solutions.map(({ key, icon }) => {
					const item = t.about.solutions[key];
					return (
						<article class="rounded-xl border border-secondary/10 bg-white p-8 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
							<div class="flex h-12 w-12 items-center justify-center rounded-lg bg-primary/5 text-primary">
								{icon === 'map' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M14.106 5.553a2 2 0 0 0 3.788 0l.894 1.789a2 2 0 0 1-1.789 2.789l-.894-.894a2 2 0 0 0-3.788 0l-.894 1.789a2 2 0 0 1-2.789 1.789l-1.789-.894a2 2 0 0 0 0 3.788l1.789.894a2 2 0 0 1 1.789 2.789l-.894.894a2 2 0 0 0 3.788 0l.894-1.789a2 2 0 0 1 2.789-1.789l1.789.894a2 2 0 0 0 0-3.788l-1.789-.894a2 2 0 0 1-1.789-2.789z"></path>
										<circle cx="12" cy="10" r="3"></circle>
										<path d="M12 2v2"></path>
										<path d="M12 20v2"></path>
										<path d="m4.93 4.93 1.41 1.41"></path>
										<path d="m17.66 17.66 1.41 1.41"></path>
										<path d="M2 12h2"></path>
										<path d="M20 12h2"></path>
										<path d="m6.34 17.66-1.41 1.41"></path>
										<path d="m19.07 4.93-1.41 1.41"></path>
									</svg>
								)}
								{icon === 'calendar' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M8 2v4"></path>
										<path d="M16 2v4"></path>
										<rect width="18" height="18" x="3" y="4" rx="2"></rect>
										<path d="M3 10h18"></path>
									</svg>
								)}
								{icon === 'users' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
										<circle cx="9" cy="7" r="4"></circle>
										<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
										<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
									</svg>
								)}
							</div>
							<h3 class="mt-6 font-heading text-xl font-semibold text-primary">{item.title}</h3>
							<p class="mt-3 text-base leading-relaxed text-secondary">{item.desc}</p>
						</article>
					);
				})
			}
		</div>

		<div class="mt-12 text-center">
			<Button href="#calendly-section">{t.about.hero.cta}</Button>
		</div>
	</div>
</section>
