---
import Button from '../../ui/Button.astro';
import Card from '../../ui/Card.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const solutions = [
	{ key: 'offsites' as const, icon: 'map' },
	{ key: 'events' as const, icon: 'calendar' },
	{ key: 'meetups' as const, icon: 'users' },
];
---

<section id="about-solutions" class="bg-canvas py-20 md:py-28" aria-labelledby="about-solutions-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal max-w-2xl">
			<p class="chapter-label">{t.about.solutions.title}</p>
			<h2 id="about-solutions-title" class="mt-3 editorial-heading text-3xl md:text-4xl">
				{t.about.solutions.title}
			</h2>
			<div class="chapter-divider"></div>
		</div>

		<div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
			{
				solutions.map(({ key, icon }, i) => {
					const item = t.about.solutions[key];
					return (
						<Card class:list={['reveal h-full', i === 1 && 'reveal-delay-1', i === 2 && 'reveal-delay-2']}>
							<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-rust/10 text-rust">
								{icon === 'map' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
										<circle cx="12" cy="10" r="3"></circle>
									</svg>
								)}
								{icon === 'calendar' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path d="M8 2v4"></path>
										<path d="M16 2v4"></path>
										<rect width="18" height="18" x="3" y="4" rx="2"></rect>
										<path d="M3 10h18"></path>
									</svg>
								)}
								{icon === 'users' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
										<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
										<circle cx="9" cy="7" r="4"></circle>
										<path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
										<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
									</svg>
								)}
							</div>
							<h3 class="mt-6 font-heading text-xl font-bold text-espresso">{item.title}</h3>
							<p class="mt-3 text-sm leading-relaxed text-muted">{item.desc}</p>
						</Card>
					);
				})
			}
		</div>

		<div class="reveal mt-12 text-center">
			<Button href="#calendly-section">{t.about.hero.cta}</Button>
		</div>
	</div>
</section>
