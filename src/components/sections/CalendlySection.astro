---
import type { Locale } from '../../i18n';
import { getTranslations } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="calendly-section" class="bg-parchment py-20 lg:py-28">
	<div class="mx-auto max-w-4xl px-6 lg:px-8">

		<!-- Section header -->
		<div class="reveal">
			<p class="font-mono text-[11px] uppercase tracking-widest text-gold">
				{t.calendly.eyebrow}
			</p>
			<h2
				class="mt-4 font-display text-[44px] font-bold leading-[1.05] text-ink lg:text-[64px]"
			>
				{t.calendly.title}
			</h2>
			<p class="mt-5 font-body text-lg leading-relaxed text-ink/60">
				{t.calendly.subtitle}
			</p>
		</div>

		<!-- Calendly placeholder widget -->
		<div class="reveal mt-12" data-delay="150">
			<div
				class="flex min-h-[600px] flex-col items-center justify-center border-2 border-gold p-8"
				style="background-color: var(--sand);"
			>
				<!-- Gold contour line decoration -->
				<div class="mb-6 flex items-center gap-4">
					<div class="h-px w-12 bg-gold/50"></div>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="#C9A84C"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
						<line x1="16" x2="16" y1="2" y2="6" />
						<line x1="8" x2="8" y1="2" y2="6" />
						<line x1="3" x2="21" y1="10" y2="10" />
					</svg>
					<div class="h-px w-12 bg-gold/50"></div>
				</div>

				<p class="font-mono text-[12px] uppercase tracking-widest text-mist">
					{t.calendly.placeholder}
				</p>

				<!-- Instruction comment (visible only here as placeholder) -->
				<p class="mt-3 text-center font-mono text-[10px] text-mist/50">
					Replace this div with the Calendly embed script
				</p>
			</div>
		</div>
	</div>
</section>
