---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const embedDomain = new URL(Astro.site ?? 'https://weoffsite.com').hostname;
const calendlySrc = `https://calendly.com/we-offsite/schedule-call?embed_domain=${embedDomain}&embed_type=Inline&hide_event_type_details=1&hide_gdpr_banner=1`;
---

<section id="calendly-section" class="bg-canvas py-20 md:py-28" aria-labelledby="calendly-title">
	<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
		<div class="reveal text-center">
			<p class="chapter-label">{t.calendly.eyebrow}</p>
			<h2 id="calendly-title" class="mt-3 editorial-heading text-3xl md:text-4xl">
				{t.calendly.title}
			</h2>
		</div>

		<div class="reveal reveal-delay-1 double-bezel mt-12">
			<div class="double-bezel-inner overflow-hidden bg-surface p-0">
				<div class="min-h-[680px] w-full md:min-h-[700px]">
					<iframe
						src={calendlySrc}
						width="100%"
						height="100%"
						class="min-h-[680px] w-full border-0 md:min-h-[700px]"
						title={t.calendly.iframeTitle}
						loading="lazy"
					></iframe>
				</div>
			</div>
		</div>
	</div>
</section>
