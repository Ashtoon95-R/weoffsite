---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section id="calendly-section" class="bg-background py-16 md:py-24" aria-labelledby="calendly-title">
	<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
		<div class="text-center">
			<p class="text-sm font-semibold uppercase tracking-widest text-accent">{t.calendly.eyebrow}</p>
			<h2 id="calendly-title" class="mt-4 font-heading text-3xl font-bold tracking-tight text-primary md:text-4xl">
				{t.calendly.title}
			</h2>
		</div>

		<div class="calendly-placeholder mt-12 flex min-h-[600px] items-center justify-center rounded-xl border border-secondary/10 bg-background shadow-md" style="min-height:600px; background: var(--color-background);">
			<!-- Calendly embed: https://calendly.com/weoffsite -->
			<!-- Instrucción: reemplaza este div con el widget script de Calendly -->
			<p class="px-6 text-center text-sm text-secondary">{t.calendly.placeholder}</p>
		</div>
	</div>
</section>
