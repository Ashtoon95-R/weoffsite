---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const logos = ['Kayzen', 'Paperlike', 'Incident.io', 'OPTI Digital', 'Balena', 'Definely', 'Graphite'];
---

<section class="overflow-hidden border-y border-secondary/10 bg-white py-10" aria-label={t.logoBar.prefix}>
	<p class="mb-6 text-center text-sm font-semibold uppercase tracking-widest text-secondary">
		{t.logoBar.prefix}
	</p>

	<div class="overflow-hidden" aria-hidden="true">
		<div class="marquee-track flex w-max items-center gap-12 px-6">
			{
				[...logos, ...logos].map((logo) => (
					<span class="flex cursor-default select-none items-center gap-3 text-sm font-semibold uppercase tracking-widest text-secondary/50 transition-colors duration-200 hover:text-primary">
						<span class="h-px w-4 bg-accent/40" aria-hidden="true"></span>
						{logo}
					</span>
				))
			}
		</div>
	</div>
</section>
