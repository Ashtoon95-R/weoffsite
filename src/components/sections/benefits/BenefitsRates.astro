---
import Button from '../../ui/Button.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="bg-white py-16 md:py-24" aria-labelledby="benefits-rates-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
			<div>
				<h2 id="benefits-rates-title" class="font-heading text-3xl font-bold tracking-tight text-primary md:text-4xl">
					{t.benefits.rates.title}
				</h2>
				<p class="mt-6 text-base leading-relaxed text-secondary md:text-lg">
					{t.benefits.rates.desc}
				</p>
				<div class="mt-8">
					<Button href="#calendly-section">{t.benefits.cta}</Button>
				</div>
			</div>
			<div
				class="flex aspect-[4/3] items-center justify-center rounded-2xl bg-gradient-to-br from-primary/5 via-accent/10 to-background p-12 shadow-md"
				aria-hidden="true"
			>
				<div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-accent/15 text-accent">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
						<line x1="19" x2="5" y1="5" y2="19"></line>
						<circle cx="6.5" cy="6.5" r="2.5"></circle>
						<circle cx="17.5" cy="17.5" r="2.5"></circle>
					</svg>
				</div>
			</div>
		</div>
	</div>
</section>
