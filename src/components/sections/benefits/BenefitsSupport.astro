---
import Button from '../../ui/Button.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const supportItems = [
	{ key: 'changes' as const, icon: 'refresh' },
	{ key: 'travel' as const, icon: 'plane' },
	{ key: 'accommodation' as const, icon: 'bed' },
	{ key: 'advice' as const, icon: 'message' },
];
---

<section class="bg-white py-16 md:py-24" aria-labelledby="benefits-support-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl text-center md:mx-auto">
			<p class="text-sm font-semibold uppercase tracking-widest text-accent">{t.benefits.support.label}</p>
			<h2 id="benefits-support-title" class="mt-4 font-heading text-3xl font-bold tracking-tight text-primary md:text-4xl">
				{t.benefits.support.title}
			</h2>
		</div>

		<div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{
				supportItems.map(({ key, icon }) => {
					const item = t.benefits.support[key];
					return (
						<article class="rounded-xl bg-background p-6 shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg">
							<div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
								{icon === 'refresh' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
										<path d="M3 3v5h5"></path>
										<path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path>
										<path d="M16 16h5v5"></path>
									</svg>
								)}
								{icon === 'plane' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 2 2 1-1v-3l3-2 3.2 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"></path>
									</svg>
								)}
								{icon === 'bed' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M2 4v16"></path>
										<path d="M2 8h18a2 2 0 0 1 2 2v10"></path>
										<path d="M2 17h20"></path>
										<path d="M6 8v9"></path>
									</svg>
								)}
								{icon === 'message' && (
									<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
									</svg>
								)}
							</div>
							<h3 class="mt-4 font-heading text-lg font-semibold text-primary">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-secondary">{item.desc}</p>
						</article>
					);
				})
			}
		</div>

		<div class="mt-14 text-center">
			<Button href="#calendly-section">{t.benefits.cta}</Button>
		</div>
	</div>
</section>
