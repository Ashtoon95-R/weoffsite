---
import Button from '../../ui/Button.astro';
import Card from '../../ui/Card.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const supportItems = ['changes', 'travel', 'accommodation', 'advice'] as const;
---

<section class="bg-canvas py-20 md:py-28" aria-labelledby="benefits-support-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal mx-auto max-w-3xl text-center">
			<p class="chapter-label">{t.benefits.support.label}</p>
			<h2 id="benefits-support-title" class="mt-4 editorial-heading text-3xl md:text-4xl">
				{t.benefits.support.title}
			</h2>
			<div class="chapter-divider mx-auto max-w-xs"></div>
		</div>

		<div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
			{
				supportItems.map((key, i) => {
					const item = t.benefits.support[key];
					return (
						<Card padding="sm" class:list={['reveal text-left', i > 0 && 'reveal-delay-1']}>
							<p class="font-mono text-[10px] uppercase tracking-wider text-sage">{String(i + 1).padStart(2, '0')}</p>
							<h3 class="mt-3 font-heading text-lg font-bold text-espresso">{item.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-muted">{item.desc}</p>
						</Card>
					);
				})
			}
		</div>

		<div class="reveal mt-14 text-center">
			<Button href="#calendly-section">{t.benefits.cta}</Button>
		</div>
	</div>
</section>
