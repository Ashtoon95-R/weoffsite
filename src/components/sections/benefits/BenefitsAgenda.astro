---
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="bg-surface py-20 md:py-28" aria-labelledby="benefits-agenda-title">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
			<div
				class="double-bezel-inner flex aspect-[4/3] items-center justify-center rounded-2xl bg-gradient-to-br from-rust/10 via-canvas to-espresso/5 p-12 shadow-editorial lg:order-1"
				aria-hidden="true"
			>
				<div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-rust/15 text-rust">
					<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
						<path d="M8 2v4"></path>
						<path d="M16 2v4"></path>
						<rect width="18" height="18" x="3" y="4" rx="2"></rect>
						<path d="M3 10h18"></path>
						<path d="M8 14h.01"></path>
						<path d="M12 14h.01"></path>
						<path d="M16 14h.01"></path>
						<path d="M8 18h.01"></path>
						<path d="M12 18h.01"></path>
					</svg>
				</div>
			</div>
			<div class="lg:order-2">
				<p class="chapter-label">{locale === 'es' ? 'Agenda' : 'Agenda'}</p>
				<h2 id="benefits-agenda-title" class="mt-3 editorial-heading text-3xl md:text-4xl">
					{t.benefits.agenda.title}
				</h2>
				<p class="mt-6 text-base leading-relaxed text-muted md:text-lg">{t.benefits.agenda.desc}</p>
			</div>
		</div>
	</div>
</section>
