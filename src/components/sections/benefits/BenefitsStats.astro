---
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const stats = [
	{ value: t.benefits.stats.stat1Value, suffix: t.benefits.stats.stat1Suffix, label: t.benefits.stats.stat1Label },
	{ value: t.benefits.stats.stat2Value, suffix: t.benefits.stats.stat2Suffix, label: t.benefits.stats.stat2Label },
	{ value: t.benefits.stats.stat3Value, suffix: t.benefits.stats.stat3Suffix, label: t.benefits.stats.stat3Label },
	{ value: t.benefits.stats.stat4Value, suffix: t.benefits.stats.stat4Suffix, label: t.benefits.stats.stat4Label },
];
---

<section class="bg-primary py-16 md:py-24" aria-labelledby="benefits-stats-label">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 divide-y divide-white/10 sm:grid-cols-2 lg:grid-cols-4 lg:divide-x lg:divide-y-0">
			{
				stats.map((stat) => (
					<div class="px-4 py-10 text-center lg:py-0">
						<p class="font-heading text-5xl font-bold leading-none text-white md:text-6xl">
							{stat.value}
							<span class="text-accent">{stat.suffix}</span>
						</p>
						<p class="mt-4 text-sm font-medium leading-snug text-white/70">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
