---
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const stats = [
	{ value: t.benefits.stats.stat1Value, suffix: t.benefits.stats.stat1Suffix, label: t.benefits.stats.stat1Label },
	{ value: t.benefits.stats.stat2Value, suffix: t.benefits.stats.stat2Suffix, label: t.benefits.stats.stat2Label },
	{ value: t.benefits.stats.stat3Value, suffix: t.benefits.stats.stat3Suffix, label: t.benefits.stats.stat3Label },
	{ value: t.benefits.stats.stat4Value, suffix: t.benefits.stats.stat4Suffix, label: t.benefits.stats.stat4Label },
];
---

<section class="border-y border-black/[0.06] bg-surface py-20 md:py-28" aria-labelledby="benefits-stats-label">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="reveal grid grid-cols-1 divide-y divide-black/[0.06] sm:grid-cols-2 lg:grid-cols-4 lg:divide-x lg:divide-y-0">
			{
				stats.map((stat, i) => (
					<div class:list={['px-4 py-10 text-center lg:py-0', i > 0 && 'reveal-delay-1']}>
						<p
							class="font-mono text-4xl font-bold tabular-nums leading-none text-espresso md:text-5xl"
							data-count-up={stat.value}
							data-count-suffix={stat.suffix}
						>
							0{stat.suffix}
						</p>
						<p class="mt-4 text-xs font-medium leading-snug text-muted">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
