---
import Button from '../../ui/Button.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section
	class="relative flex min-h-[70vh] items-center overflow-hidden"
	aria-labelledby="benefits-hero-title"
>
	<div
		class="absolute inset-0 bg-gradient-to-br from-primary via-secondary to-accent"
		aria-hidden="true"
	></div>
	<div
		class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(3,105,161,0.35),transparent_55%)]"
		aria-hidden="true"
	></div>
	<div class="absolute inset-0 bg-black/20" aria-hidden="true"></div>

	<div class="relative mx-auto w-full max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-widest text-white/70">{t.benefits.hero.label}</p>
			<h1
				id="benefits-hero-title"
				class="mt-4 font-heading text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl"
			>
				{t.benefits.hero.title}
			</h1>
			<p class="mt-6 max-w-2xl text-base leading-relaxed text-white/90 sm:text-lg md:text-xl">
				{t.benefits.hero.subtitle}
			</p>
			<div class="mt-10">
				<Button href="#calendly-section">{t.benefits.cta}</Button>
			</div>
		</div>
	</div>
</section>
