---
import Button from '../../ui/Button.astro';
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section
	class="editorial-hero-bg relative flex min-h-[70vh] items-center overflow-hidden border-b border-black/[0.06] pt-28 pb-20 md:pt-32"
	aria-labelledby="benefits-hero-title"
>
	<div class="relative mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<div class="reveal max-w-3xl">
			<p class="chapter-label">{t.benefits.hero.label}</p>
			<h1
				id="benefits-hero-title"
				class="editorial-heading mt-4 text-[clamp(2rem,5vw,3.5rem)] leading-tight"
			>
				{t.benefits.hero.title}
			</h1>
			<p class="mt-6 max-w-2xl text-base leading-relaxed text-muted sm:text-lg md:text-xl">
				{t.benefits.hero.subtitle}
			</p>
			<div class="mt-10">
				<Button href="#calendly-section">{t.benefits.cta}</Button>
			</div>
		</div>
	</div>
</section>
