---
import { getTranslations, type Locale } from '../../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="bg-canvas py-20 md:py-28" aria-labelledby="benefits-expense-title">
	<div class="reveal mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
		<p class="chapter-label">{locale === 'es' ? 'Presupuesto' : 'Budget'}</p>
		<h2 id="benefits-expense-title" class="mt-3 editorial-heading text-3xl md:text-4xl">
			{t.benefits.expense.title}
		</h2>
		<p class="mt-6 text-base leading-relaxed text-muted md:text-lg">{t.benefits.expense.desc}</p>
	</div>
</section>
