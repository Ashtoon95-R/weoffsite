---
import { getCollection } from 'astro:content';
import Button from '../ui/Button.astro';
import CaseStudyCover from '../ui/CaseStudyCover.astro';
import { getTranslations, type Locale } from '../../i18n';
import { getCaseStudySlug } from '../../utils/case-studies';
import { getCaseStudyCoverImage } from '../../utils/case-study-images';
import { localePath } from '../../utils/paths';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const studies = (await getCollection('case-studies', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const featuredStudy = studies[0];
const featuredCover = featuredStudy ? getCaseStudyCoverImage(getCaseStudySlug(featuredStudy.id)) : undefined;

const trustBadges = [
	{ value: `${t.stats.stat1Value}${t.stats.stat1Suffix}`, label: t.stats.stat1Label },
	{ value: `${t.stats.stat2Value}${t.stats.stat2Suffix}`, label: t.stats.stat2Label },
];
---

<section
	class="relative min-h-[calc(100dvh-5rem)] pt-24 pb-16 md:pt-28 md:pb-24"
	aria-labelledby="hero-title"
>
	<div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
		<div>
			<h1
				id="hero-title"
				class="reveal mt-4 font-heading text-[clamp(2.25rem,5vw,3.75rem)] font-bold leading-[1.05] tracking-tight text-espresso"
				style="letter-spacing: -0.03em;"
			>
				{t.hero.title.split('80%').map((part, index, parts) => (
					<>
						{part}
						{index < parts.length - 1 && (
							<span class="text-rust underline decoration-gold decoration-2 underline-offset-4">80%</span>
						)}
					</>
				))}
			</h1>

			<p class="reveal reveal-delay-1 mt-6 max-w-lg text-lg leading-relaxed text-muted">
				{t.hero.subtitle}
			</p>

			<div class="reveal reveal-delay-2 mt-8 grid max-w-md grid-cols-2 gap-3">
				{trustBadges.map((badge) => (
					<div class="rounded-full border border-sage/20 bg-sage/5 px-4 py-2">
						<p class="font-mono text-sm font-bold text-espresso">{badge.value}</p>
						<p class="font-mono text-[10px] uppercase tracking-wider text-sage">{badge.label}</p>
					</div>
				))}
			</div>

			<div class="reveal reveal-delay-3 mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
				<Button href="#calendly-section">{t.hero.ctaPrimary}</Button>
				<a
					href={localePath(locale, 'case-studies')}
					class="cursor-pointer text-center text-base font-semibold text-espresso underline-offset-4 transition-all duration-200 hover:text-rust hover:underline"
				>
					{t.hero.ctaSecondary}
				</a>
			</div>
		</div>

		{
			featuredStudy && (
				<div class="reveal reveal-delay-2 relative">
					<div class="double-bezel">
						<div class="double-bezel-inner overflow-hidden shadow-editorial">
							{featuredCover ? (
								<CaseStudyCover
									src={featuredCover}
									alt={`${featuredStudy.data.company} — ${featuredStudy.data.location}`}
									variant="hero"
									loading="eager"
									class="aspect-[4/5] w-full object-cover"
								/>
							) : (
								<div
									class="aspect-[4/5] w-full bg-gradient-to-br from-espresso/5 via-rust/10 to-sage/10"
									role="img"
									aria-label={`${featuredStudy.data.company} — ${featuredStudy.data.location}`}
								></div>
							)}
						</div>
					</div>
					<div class="absolute -bottom-4 -left-4 hidden rounded-2xl border border-black/[0.06] bg-white/90 px-5 py-4 shadow-editorial backdrop-blur-sm md:block">
						<p class="font-mono text-[10px] uppercase tracking-[0.2em] text-sage">{featuredStudy.data.location}</p>
						<p class="mt-1 font-heading text-sm font-bold text-espresso">{featuredStudy.data.company}</p>
					</div>
				</div>
			)
		}
	</div>
</section>
