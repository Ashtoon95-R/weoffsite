---
import dubaiImg from '../../assets/hero-carousel/dubai-capslock.webp';
import parkCityImg from '../../assets/hero-carousel/park-city-graphite.webp';
import phuketImg from '../../assets/hero-carousel/phuket-kayzen.webp';
import washingtonImg from '../../assets/hero-carousel/washington-incident.webp';
import athensImg from '../../assets/hero-carousel/athens-incident.webp';
import Button from '../ui/Button.astro';
import { getTranslations, type Locale } from '../../i18n';
import { localePath } from '../../utils/paths';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const carouselImages = [dubaiImg, parkCityImg, phuketImg, washingtonImg, athensImg];

const slides = t.hero.slides.map((slide, index) => ({
	...slide,
	image: carouselImages[index],
}));

const trustBadges = [
	{ value: `${t.hero.badge1Value}${t.hero.badge1Suffix}`, label: t.hero.badge1Label },
	{ value: `${t.hero.badge2Value}${t.hero.badge2Suffix}`, label: t.hero.badge2Label },
];
---

<section
	class="relative min-h-[calc(100dvh-5rem)] pt-24 pb-16 md:pt-28 md:pb-24"
	aria-labelledby="hero-title"
>
	<div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-2 lg:gap-16 lg:px-8">
		<div>
			<h1
				id="hero-title"
				class="reveal mt-4 font-heading text-[clamp(2.25rem,5vw,3.75rem)] font-bold leading-[1.05] tracking-tight text-espresso"
				style="letter-spacing: -0.03em;"
			>
				{t.hero.title.split('80%').map((part, index, parts) => (
					<>
						{part}
						{index < parts.length - 1 && <span class="text-rust">80%</span>}
					</>
				))}
			</h1>

			<p class="reveal reveal-delay-1 mt-6 max-w-lg text-lg leading-relaxed text-muted">
				{t.hero.subtitle}
			</p>

			<div class="reveal reveal-delay-2 mt-8 grid max-w-md grid-cols-2 gap-3">
				{trustBadges.map((badge) => (
					<div class="rounded-full border border-sage/20 bg-sage/5 px-4 py-2">
						<p class="font-mono text-sm font-bold text-espresso">{badge.value}</p>
						<p class="font-mono text-[10px] uppercase tracking-wider text-sage">{badge.label}</p>
					</div>
				))}
			</div>

			<div class="reveal reveal-delay-3 mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
				<Button href="#calendly-section">{t.hero.ctaPrimary}</Button>
				<a
					href={localePath(locale, 'case-studies')}
					class="cursor-pointer text-center text-base font-semibold text-espresso underline-offset-4 transition-all duration-200 hover:text-rust hover:underline"
				>
					{t.hero.ctaSecondary}
				</a>
			</div>
		</div>

		<div class="reveal reveal-delay-2 relative" data-hero-carousel>
			<div class="double-bezel">
				<div class="double-bezel-inner overflow-hidden shadow-editorial">
					<div class="hero-carousel relative aspect-[4/5] w-full bg-espresso/5">
						{
							slides.map((slide, index) => (
								<div
									data-hero-slide
									class:list={['hero-carousel-slide', index === 0 && 'is-active']}
									aria-hidden={index !== 0}
								>
									<img
										src={slide.image.src}
										alt={`${slide.company} — ${slide.location}`}
										width={slide.image.width}
										height={slide.image.height}
										sizes="(min-width: 1024px) 480px, 100vw"
										loading={index === 0 ? 'eager' : 'lazy'}
										decoding="async"
										class="h-full w-full object-cover"
									/>
								</div>
							))
						}
					</div>
				</div>
			</div>
			<div class="absolute -bottom-4 -left-4 z-10 hidden w-max rounded-2xl border border-black/[0.06] bg-white/90 px-5 py-4 shadow-editorial backdrop-blur-sm md:block">
				<div class="grid [&>[data-hero-caption]]:col-start-1 [&>[data-hero-caption]]:row-start-1">
					{
						slides.map((slide, index) => (
							<div
								data-hero-caption
								class:list={['hero-carousel-caption', index === 0 && 'is-active']}
								aria-hidden={index !== 0}
							>
								<p class="font-mono text-[10px] uppercase tracking-[0.2em] text-sage">{slide.location}</p>
								<p class="mt-1 font-heading text-sm font-bold text-espresso">{slide.company}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>

<script src="../../scripts/hero-carousel.ts"></script>
