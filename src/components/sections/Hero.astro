---
import Button from '../ui/Button.astro';
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section
	class="relative flex min-h-[calc(100vh-4.5rem)] items-center overflow-hidden"
	aria-labelledby="hero-title"
>
	<div
		class="absolute inset-0 bg-gradient-to-br from-primary via-secondary to-accent"
		aria-hidden="true"
	></div>
	<div
		class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(3,105,161,0.35),transparent_55%)]"
		aria-hidden="true"
	></div>
	<div class="absolute inset-0 bg-black/20" aria-hidden="true"></div>

	<div class="relative mx-auto w-full max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
		<div class="max-w-3xl">
			<h1
				id="hero-title"
				class="font-heading text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl md:text-5xl lg:text-6xl"
			>
				{t.hero.title}
			</h1>
			<p class="mt-6 max-w-2xl text-base leading-relaxed text-white/90 sm:text-lg md:text-xl">
				{t.hero.subtitle}
			</p>
			<div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
				<Button href="#calendly-section">{t.hero.ctaPrimary}</Button>
				<a
					href={locale === 'es' ? '/es/case-studies' : '/en/case-studies'}
					class="cursor-pointer text-center text-base font-semibold text-white underline-offset-4 transition-all duration-200 hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
				>
					{t.hero.ctaSecondary}
				</a>
			</div>
		</div>
	</div>
</section>
