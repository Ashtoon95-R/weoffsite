---
import { getCollection } from 'astro:content';
import { getTranslations, type Locale } from '../../i18n';
import { getCaseStudySlug } from '../../utils/case-studies';

interface Props {
	locale: Locale;
	hideHeader?: boolean;
}

const { locale, hideHeader = false } = Astro.props;
const t = getTranslations(locale);
const studies = (await getCollection('case-studies', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const basePath = `/${locale}/case-studies`;
---

<section
	id="case-studies"
	class="bg-background py-16 md:py-24"
	aria-labelledby={hideHeader ? undefined : 'case-studies-title'}
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		{
			!hideHeader && (
				<div class="max-w-2xl">
					<h2 id="case-studies-title" class="font-heading text-3xl font-bold tracking-tight text-primary md:text-4xl">
						{t.caseStudies.title}
					</h2>
					<p class="mt-4 text-lg text-secondary">{t.caseStudies.subtitle}</p>
				</div>
			)
		}

		<div class:list={['grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3', !hideHeader && 'mt-12']}>
			{
				studies.map((study) => (
					<article class="group flex cursor-pointer flex-col overflow-hidden rounded-xl bg-white shadow-md transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg">
						<div
							class="aspect-[16/10] bg-gradient-to-br from-primary/10 via-secondary/10 to-accent/20"
							style={`background-image: url(${study.data.coverImage}); background-size: cover; background-position: center;`}
							role="img"
							aria-label={`${study.data.company} — ${study.data.location}`}
						></div>
						<div class="flex flex-1 flex-col p-6">
							<div class="flex items-center gap-1.5 text-sm font-medium text-secondary">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									class="shrink-0 text-accent"
									aria-hidden="true"
								>
									<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
									<circle cx="12" cy="10" r="3"></circle>
								</svg>
								<span>{study.data.location}</span>
							</div>
							<h3 class="mt-3 font-heading text-lg font-semibold text-primary group-hover:text-accent transition-colors duration-200">
								{study.data.title}
							</h3>
							<blockquote class="mt-3 flex-1 text-sm leading-relaxed text-text">
								<p class="line-clamp-4">"{study.data.quote}"</p>
							</blockquote>
							<a
								href={`${basePath}/${getCaseStudySlug(study.id)}`}
								class="mt-5 inline-flex cursor-pointer items-center gap-1 text-sm font-semibold text-accent transition-colors duration-200 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
							>
								{t.caseStudies.viewFull}
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="16"
									height="16"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									aria-hidden="true"
								>
									<path d="M5 12h14"></path>
									<path d="m12 5 7 7-7 7"></path>
								</svg>
							</a>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.line-clamp-4 {
		display: -webkit-box;
		-webkit-line-clamp: 4;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
