---
import { getCollection } from 'astro:content';
import CaseStudyCover from '../ui/CaseStudyCover.astro';
import { getTranslations, type Locale } from '../../i18n';
import { getCaseStudySlug } from '../../utils/case-studies';
import { getCaseStudyCoverImage } from '../../utils/case-study-images';

interface Props {
	locale: Locale;
	hideHeader?: boolean;
}

const { locale, hideHeader = false } = Astro.props;
const t = getTranslations(locale);
const studies = (await getCollection('case-studies', ({ data }) => data.lang === locale)).sort(
	(a, b) => a.data.order - b.data.order,
);
const basePath = `/${locale}/case-studies`;
const [featured, ...rest] = studies;
---

<section
	id="case-studies"
	class="bg-surface py-20 md:py-28"
	aria-labelledby={hideHeader ? undefined : 'case-studies-title'}
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		{
			!hideHeader && (
				<div class="reveal max-w-2xl">
					<p class="chapter-label">{t.caseStudies.label}</p>
					<h2 id="case-studies-title" class="mt-3 editorial-heading text-3xl md:text-4xl lg:text-5xl">
						{t.caseStudies.title}
					</h2>
					<p class="mt-4 text-lg leading-relaxed text-muted">{t.caseStudies.subtitle}</p>
					<div class="chapter-divider" />
				</div>
			)
		}

		<div class:list={['grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-8', !hideHeader && 'mt-4']}>
			{
				featured && (() => {
					const featuredCover = getCaseStudyCoverImage(getCaseStudySlug(featured.id));
					return (
					<article class="reveal glare-card group lg:col-span-8">
						<a href={`${basePath}/${getCaseStudySlug(featured.id)}`} class="double-bezel block h-full cursor-pointer">
							<div class="double-bezel-inner flex h-full flex-col overflow-hidden p-0">
								<div class="relative aspect-[16/10] overflow-hidden img-skeleton">
									{featuredCover ? (
										<CaseStudyCover
											src={featuredCover}
											alt={`${featured.data.company} — ${featured.data.location}`}
											variant="featured"
											class="h-full w-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-105"
											onload="this.parentElement.classList.remove('img-skeleton')"
										/>
									) : (
										<div class="h-full w-full bg-gradient-to-br from-espresso/10 via-rust/15 to-sage/15" />
									)}
								</div>
								<div class="flex flex-1 flex-col p-8">
									<p class="font-mono text-xs uppercase tracking-wider text-sage">{featured.data.location}</p>
									<h3 class="mt-2 font-heading text-2xl font-bold text-espresso transition-colors duration-200 group-hover:text-rust">
										{featured.data.title}
									</h3>
									<blockquote class="mt-4 flex-1 text-base leading-relaxed text-muted">
										<p class="line-clamp-3 italic">"{featured.data.quote}"</p>
									</blockquote>
									<span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-rust">
										{t.caseStudies.viewFull}
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
											<path d="M5 12h14"></path>
											<path d="m12 5 7 7-7 7"></path>
										</svg>
									</span>
								</div>
							</div>
						</a>
					</article>
					);
				})()
			}

			<div class="flex flex-col gap-6 lg:col-span-4">
				{
					rest.slice(0, 2).map((study, i) => {
						const cover = getCaseStudyCoverImage(getCaseStudySlug(study.id));
						return (
						<article class:list={['reveal glare-card group', i === 1 && 'reveal-delay-1']}>
							<a href={`${basePath}/${getCaseStudySlug(study.id)}`} class="double-bezel block h-full cursor-pointer">
								<div class="double-bezel-inner flex h-full flex-col overflow-hidden p-0">
									<div class="relative aspect-[16/10] overflow-hidden img-skeleton">
										{cover ? (
											<CaseStudyCover
												src={cover}
												alt={`${study.data.company} — ${study.data.location}`}
												variant="card"
												class="h-full w-full object-cover transition-transform duration-700 ease-editorial group-hover:scale-105"
												onload="this.parentElement.classList.remove('img-skeleton')"
											/>
										) : (
											<div class="h-full w-full bg-gradient-to-br from-espresso/10 via-rust/15 to-sage/15" />
										)}
									</div>
									<div class="flex flex-1 flex-col p-6">
										<p class="font-mono text-[10px] uppercase tracking-wider text-sage">{study.data.location}</p>
										<h3 class="mt-2 font-heading text-lg font-bold text-espresso group-hover:text-rust">{study.data.title}</h3>
										<span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-rust">
											{t.caseStudies.viewFull}
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
												<path d="M5 12h14"></path>
												<path d="m12 5 7 7-7 7"></path>
											</svg>
										</span>
									</div>
								</div>
							</a>
						</article>
						);
					})
				}
			</div>
		</div>

		{
			rest.length > 2 && (
				<div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{rest.slice(2).map((study) => {
						const cover = getCaseStudyCoverImage(getCaseStudySlug(study.id));
						return (
						<article class="reveal glare-card group">
							<a href={`${basePath}/${getCaseStudySlug(study.id)}`} class="double-bezel block cursor-pointer">
								<div class="double-bezel-inner overflow-hidden p-0">
									<div class="relative aspect-[16/10] img-skeleton">
										{cover ? (
											<CaseStudyCover
												src={cover}
												alt={study.data.company}
												variant="thumb"
												class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
												onload="this.parentElement.classList.remove('img-skeleton')"
											/>
										) : (
											<div class="h-full w-full bg-gradient-to-br from-espresso/10 via-rust/15 to-sage/15" />
										)}
									</div>
									<div class="p-5">
										<h3 class="font-heading text-base font-bold text-espresso">{study.data.company}</h3>
										<p class="mt-1 font-mono text-[10px] uppercase text-sage">{study.data.location}</p>
									</div>
								</div>
							</a>
						</article>
						);
					})}
				</div>
			)
		}
	</div>
</section>

<style>
	.line-clamp-3 {
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
