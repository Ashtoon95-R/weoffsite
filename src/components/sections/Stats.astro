---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const stats = [
	{ value: t.stats.stat1Value, suffix: t.stats.stat1Suffix, label: t.stats.stat1Label, isDecimal: false },
	{ value: t.stats.stat2Value, suffix: t.stats.stat2Suffix, label: t.stats.stat2Label, isDecimal: false },
	{ value: t.stats.stat3Value, suffix: t.stats.stat3Suffix, label: t.stats.stat3Label, isDecimal: true },
];
---

<section class="border-y border-black/[0.06] bg-canvas py-20 md:py-28" aria-labelledby="stats-label">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<p id="stats-label" class="reveal chapter-label text-center">{t.stats.label}</p>

		<div class="reveal reveal-delay-1 mt-14 grid grid-cols-1 divide-y divide-black/[0.06] md:grid-cols-3 md:divide-x md:divide-y-0">
			{
				stats.map((stat, i) => (
					<div class:list={['py-10 text-center md:px-8 md:py-0', i === 1 && 'reveal-delay-2']}>
						<p
							class="font-mono text-5xl font-bold tabular-nums leading-none text-espresso md:text-6xl lg:text-7xl"
							data-count-up={stat.value}
							data-count-suffix={stat.suffix}
							data-count-duration="1400"
						>
							0{stat.suffix}
						</p>
						<p class="mt-4 font-mono text-xs uppercase tracking-[0.15em] text-muted">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
