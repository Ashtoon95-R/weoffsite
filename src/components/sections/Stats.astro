---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);

const stats = [
	{ value: t.stats.stat1Value, suffix: t.stats.stat1Suffix, label: t.stats.stat1Label },
	{ value: t.stats.stat2Value, suffix: t.stats.stat2Suffix, label: t.stats.stat2Label },
	{ value: t.stats.stat3Value, suffix: t.stats.stat3Suffix, label: t.stats.stat3Label },
];
---

<section class="bg-primary py-16 md:py-24" aria-labelledby="stats-label">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<p id="stats-label" class="mb-14 text-center text-sm font-semibold uppercase tracking-widest text-white/70">
			{t.stats.label}
		</p>

		<div class="grid grid-cols-1 divide-y divide-white/10 md:grid-cols-3 md:divide-x md:divide-y-0">
			{
				stats.map((stat) => (
					<div class="py-10 text-center md:px-8 md:py-0">
						<p class="font-heading text-5xl font-bold leading-none text-white md:text-6xl lg:text-7xl">
							{stat.value}
							{stat.suffix}
						</p>
						<p class="mt-4 text-sm font-medium uppercase tracking-widest text-white/70">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
