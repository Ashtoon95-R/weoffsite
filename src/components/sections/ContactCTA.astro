---
import Button from '../ui/Button.astro';
import { getTranslations, type Locale } from '../../i18n';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
---

<section class="bg-primary py-16 md:py-24" aria-labelledby="contact-cta-title">
	<div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
		<p class="text-sm font-semibold uppercase tracking-widest text-white/70">{t.cta.eyebrow}</p>
		<h2 id="contact-cta-title" class="mt-4 font-heading text-3xl font-bold tracking-tight text-white md:text-4xl">
			{t.cta.title}
		</h2>
		<p class="mt-6 text-lg leading-relaxed text-white/85">{t.cta.subtitle}</p>
		<div class="mt-10">
			<Button href="#calendly-section">{t.cta.button}</Button>
		</div>
	</div>
</section>
