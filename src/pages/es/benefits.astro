---
import Layout from '../../components/layout/Layout.astro';
import BenefitsHero from '../../components/sections/benefits/BenefitsHero.astro';
import BenefitsFeatures from '../../components/sections/benefits/BenefitsFeatures.astro';
import BenefitsExpense from '../../components/sections/benefits/BenefitsExpense.astro';
import BenefitsStats from '../../components/sections/benefits/BenefitsStats.astro';
import BenefitsRates from '../../components/sections/benefits/BenefitsRates.astro';
import BenefitsAgenda from '../../components/sections/benefits/BenefitsAgenda.astro';
import BenefitsSupport from '../../components/sections/benefits/BenefitsSupport.astro';
import CalendlySection from '../../components/sections/CalendlySection.astro';
import { getTranslations } from '../../i18n';

const locale = 'es';
const t = getTranslations(locale);
---

<Layout title={t.benefits.meta.title} description={t.benefits.meta.description} lang={locale}>
	<BenefitsHero locale={locale} />
	<BenefitsFeatures locale={locale} />
	<BenefitsExpense locale={locale} />
	<BenefitsStats locale={locale} />
	<BenefitsRates locale={locale} />
	<BenefitsAgenda locale={locale} />
	<BenefitsSupport locale={locale} />
	<CalendlySection locale={locale} />
</Layout>
