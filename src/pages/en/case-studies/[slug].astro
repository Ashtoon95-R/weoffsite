---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../components/layout/Layout.astro';
import CaseStudyArticle from '../../../components/sections/case-studies/CaseStudyArticle.astro';
import { getTranslations } from '../../../i18n';
import { getCaseStudySlug } from '../../../utils/case-studies';
import { getCaseStudyCoverImage } from '../../../utils/case-study-assets';
import { localeHome, localePath } from '../../../utils/paths';

export async function getStaticPaths() {
	const locale = 'en';
	const entries = await getCollection('case-studies', ({ data }) => data.lang === locale);
	return entries.map((entry) => ({
		params: { slug: getCaseStudySlug(entry.id) },
		props: { entry },
	}));
}

interface Props {
	entry: CollectionEntry<'case-studies'>;
}

const { entry } = Astro.props;
const locale = 'en';
const t = getTranslations(locale);
const { title, quote } = entry.data;
const coverImage = getCaseStudyCoverImage(getCaseStudySlug(entry.id));
---

<Layout title={`${title} — We Offsite`} description={quote} lang={locale}>
	<CaseStudyArticle
		entry={entry}
		locale={locale}
		coverImage={coverImage}
		backHref={localePath('en', 'case-studies')}
		ctaHref={`${localeHome('en')}#calendly-section`}
		backLabel={t.caseStudyDetail.backLink}
		galleryHeading={t.caseStudyDetail.galleryHeading}
		galleryExpandLabel={t.caseStudyDetail.galleryExpandLabel}
		ctaLabel={t.caseStudyDetail.ctaButton}
		ctaHeading={t.caseStudyDetail.ctaHeading}
	/>
</Layout>
